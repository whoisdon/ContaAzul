{
  "name": "contaazul-cli",
  "version": "0.1.0",
  "description": "CLI profissional para a API pública Conta Azul Pro (ERP)",
  "type": "module",
  "bin": {
    "contaazul": "./dist/bin/contaazul.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/bin/contaazul.ts",
    "start": "node dist/bin/contaazul.js",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "conta-azul",
    "contaazul",
    "erp",
    "cli",
    "oauth",
    "api",
    "financeiro",
    "nf-e"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.1",
    "axios": "^1.9.0",
    "axios-retry": "^4.5.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "conf": "^13.1.0",
    "dotenv": "^16.5.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
